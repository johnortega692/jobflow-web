# Copy to .env.local and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI paint import (server-side only — do NOT prefix with VITE_)
# Local: add to .env.local | Vercel: Project Settings → Environment Variables
# ANTHROPIC_API_KEY=sk-ant-...

# Optional — letterhead on Print / Save PDF
# VITE_COMPANY_NAME=Plan B Apps
# VITE_COMPANY_ADDRESS=123 Main St, City, ST 00000
# VITE_COMPANY_PHONE=(555) 555-5555
# VITE_SIGNER_NAME=John Ortega
# VITE_SIGNER_EMAIL=you@company.com
